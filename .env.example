# Prism - Environment Variables
# Copy to .env and fill in required values before running docker-compose up
#
# HYBRID SETUP: Prism containers (Postgres, Redis, RabbitMQ, Qdrant, MinIO) run
# in Docker. Ollama and Airflow run on your host. Use host.docker.internal so
# Prism services can reach them. On native Linux, use 172.17.0.1 or host LAN IP.

# ---- Postgres (Prism app database) ----
POSTGRES_USER=prism
POSTGRES_PASSWORD=changeme
POSTGRES_DB=prism
POSTGRES_HOST=localhost
POSTGRES_PORT=5435

# ---- RabbitMQ ----
# Airflow on host connects via localhost:5672 (AMQP), localhost:15672 (management)
RABBITMQ_DEFAULT_USER=prism
RABBITMQ_DEFAULT_PASS=changeme

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6380

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ---- Qdrant ----
# QDRANT_HOST=localhost
# QDRANT_PORT=6336

# ---- External services (host machine) ----
OLLAMA_HOST=http://host.docker.internal:11434
AIRFLOW_API_URL=http://host.docker.internal:8080/api/v1

# ---- LLM providers (optional; for LangGraph workers) ----
# LLM_MAP_PROVIDER=ollama
# LLM_JUDGE_PROVIDER=ollama
# LLM_RAG_PROVIDER=ollama
# LLM_DEFAULT_PROVIDER=ollama
# LLM_DEFAULT_MODEL=llama3.2
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
