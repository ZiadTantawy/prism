# Prism — copy to .env and fill in. All services and app Settings read from .env.
# Sensitive values (passwords, API keys) use SecretStr in Settings; do not commit .env.

# ---- Postgres (app + docker-compose) ----
POSTGRES_USER=prism
POSTGRES_PASSWORD=password
POSTGRES_DB=prism
# Optional: override for Settings (defaults: postgres, 5432)
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=prism
RABBITMQ_DEFAULT_PASS=password
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672

# ---- Redis ----
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=password
# MINIO_HOST=minio
# MINIO_PORT=9000
MINIO_BUCKET=prism

# ---- Qdrant ----
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_PASSWORD=

# ---- Airflow (orchestration metadata DB) ----
AIRFLOW_UID=50000
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=password
AIRFLOW_POSTGRES_DB=airflow
# AIRFLOW_HOST=airflow-db
# AIRFLOW_PORT=5432

# ---- Observability: Prometheus & Grafana ----
# PROMETHEUS_HOST=prometheus
# PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
# GRAFANA_HOST=grafana
# GRAFANA_PORT=3000

# ---- Ollama (optional; docker-compose --profile llm-local). API at http://ollama:11434 on Docker network ----
# When app runs in Docker, use host "ollama". When app runs on host, use "localhost".
# OLLAMA_HOST=ollama
# OLLAMA_PORT=11434

# ---- Optional: Sentry (errors) ----
# SENTRY_DSN=

# ---- Optional: LangSmith (tracing) ----
# LANGSMITH_API_KEY=

# ---- Optional: Langfuse (tracing/evals) ----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ---- LLM API keys (optional; set when using that provider) ----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENAI_BASE_URL=   # Azure, proxy, or OpenAI-compatible endpoint

# ---- LLM provider defaults (Settings) ----
# LLM_DEFAULT_PROVIDER=ollama
# LLM_DEFAULT_MODEL=llama3.2
# Per-role overrides (optional):
# LLM_MAP_PROVIDER=
# LLM_MAP_MODEL=
# LLM_JUDGE_PROVIDER=
# LLM_JUDGE_MODEL=
# LLM_RAG_PROVIDER=
# LLM_RAG_MODEL=
# LLM_CHAT_PROVIDER=
# LLM_CHAT_MODEL=

# ---- Legacy / URL-style (used by some code or docker-compose; Settings builds URLs from above) ----
# ASYNC_DATABASE_URL=postgresql+asyncpg://prism:password@postgres:5432/prism
# DATABASE_URL=postgresql+psycopg2://prism:password@localhost:5435/prism
# REDIS_URL=redis://redis:6379/0
# RABBITMQ_URL=amqp://prism:password@rabbitmq:5672/
# QDRANT_URL=http://qdrant:6333
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=password
# MINIO_SECURE=0
